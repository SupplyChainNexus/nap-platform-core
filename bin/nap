#!/usr/bin/env php
<?php

declare(strict_types=1);

require_once __DIR__ . "/../vendor/autoload.php";

use NAP\Infrastructure\Persistence\OutboxPublisher;
use NAP\SharedKernel\EnvironmentLoader;

EnvironmentLoader::load(__DIR__ . "/../.env.example");

$command = $argv[1] ?? "help";

if ($command !== "worker") {
    echo "NAP Platform Core CLI\n";
    echo "Usage: php bin/nap worker\n";
    exit(0);
}

echo "[NAP Worker] Daemon started. Polling outbox every 2 second(s)...\n";

try {
    $dbPath = __DIR__ . "/../database.sqlite";
    if (!file_exists($dbPath)) {
        touch($dbPath);
    }
    $pdo = new PDO("sqlite:" . $dbPath);
    $pdo->setAttribute(PDO::ATTR_ERRMODE, PDO::ERRMODE_EXCEPTION);

    // Create outbox_messages table matching exact OutboxPublisher schema
    $pdo->exec("CREATE TABLE IF NOT EXISTS outbox_messages (
        id INTEGER PRIMARY KEY AUTOINCREMENT,
        event_type TEXT NOT NULL,
        payload TEXT NOT NULL,
        created_at TEXT NOT NULL,
        published_at TEXT DEFAULT NULL
    )");
    
    // Auto-migrate column if database was created with old schema
    try {
        $pdo->exec("ALTER TABLE outbox_messages ADD COLUMN published_at TEXT DEFAULT NULL");
    } catch (\Throwable $ignored) {}
} catch (\Throwable $e) {
    echo "[NAP Worker Error] Database initialization failed: " . $e->getMessage() . "\n";
    exit(1);
}

$publisher = new OutboxPublisher($pdo);

while (true) {
    try {
        $processedCount = $publisher->processPending(function (array $eventData): void {
            echo sprintf("[%s] [DISPATCH] Event: %s\n", date("Y-m-d H:i:s"), $eventData["event_type"] ?? "unknown");
        });
        
        if ($processedCount > 0) {
            echo sprintf("[%s] Processed & dispatched %d outbox message(s)\n", date("Y-m-d H:i:s"), $processedCount);
        }
    } catch (\Throwable $e) {
        echo sprintf("[%s] Worker error: %s\n", date("Y-m-d H:i:s"), $e->getMessage());
    }
    sleep(2);
}
