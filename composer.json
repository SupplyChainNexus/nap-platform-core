{
    "name": "nap/nap-platform-core",
    "description": "Core architecture for NAP Platform",
    "type": "library",
    "license": "proprietary",

    "autoload": {
        "psr-4": {
            "NAP\\": "src/"
        }
    },

    "autoload-dev": {
        "psr-4": {
            "NAP\\Tests\\": "tests/"
        }
    },

    "require": {
        "php": ">=8.2"
    },

    "require-dev": {
        "phpunit/phpunit": "^10.0",
        "phpstan/phpstan": "^1.10",
        "phpat/phpat": "^0.10.0"
    },

    "config": {
        "optimize-autoloader": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": true
        }
    }
}